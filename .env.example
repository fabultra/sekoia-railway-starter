# MongoDB - obligatoire
MONGODB_URI=mongodb://localhost:27017/klide_v2

# NextAuth - obligatoire
# Genere via: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# LLM providers - optionnels (laisser vide skip le provider proprement)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=

# Email - optionnel
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@klide.ai

# Mode test - force le fake provider deterministe pour les LLMs (utile en CI/E2E)
KLIDE_FAKE_LLMS=false
